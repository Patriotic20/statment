# Copy to .env and adjust. Credentials must match docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://rrtm:rrtm@localhost:5432/rrtm

# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
