# Скопируйте в .env и заполните. Используется docker-compose.prod.yml на сервере.
# Реальный .env в git не коммитится (см. .gitignore).

# Токены Telegram-ботов
WORKER_BOT_TOKEN=
CLIENT_BOT_TOKEN=

# Секрет для подписи JWT. Сгенерировать:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
